{
  "name": "@shadow-cloud/web",
  "version": "0.4.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "build": "dotenv -e ../../.env -- next build",
    "start": "dotenv -e ../../.env -- next start",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.mjs\" \"*.{ts,mjs}\"",
    "lint": "eslint .",
    "typecheck": "node ./scripts/typecheck.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.2",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv-cli": "11.0.0",
    "eslint": "10.2.1",
    "eslint-config-next": "16.2.4",
    "prettier": "3.8.3",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3"
  }
}
