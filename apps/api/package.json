{
  "name": "@shadow-cloud/api",
  "version": "0.1.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "pnpm run prisma:generate && nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "dotenv -e ../../.env -- nest start",
    "dev": "dotenv -e ../../.env -- nest start --watch",
    "start:dev": "dotenv -e ../../.env -- nest start --watch",
    "start:debug": "dotenv -e ../../.env -- nest start --debug --watch",
    "start:prod": "dotenv -e ../../.env -- node dist/main",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev --schema prisma/schema.prisma",
    "prisma:push": "dotenv -e ../../.env -- prisma db push --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "jose": "^6.2.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "dotenv-cli": "11.0.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.5.0",
    "prettier": "3.8.3",
    "prisma": "7.8.0",
    "source-map-support": "0.5.21",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0"
  }
}
