{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shadow-Cloud Desktop",
  "version": "0.7.0",
  "identifier": "com.shadowcloud.desktop",
  "build": {
    "beforeDevCommand": "pnpm vite --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Shadow-Cloud Desktop",
        "width": 1120,
        "height": 760,
        "minWidth": 860,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["shadow-cloud"]
      }
    }
  }
}
